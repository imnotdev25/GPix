# gpix environment variables.
# Copy this file to .env and fill in the values you need.
#
# Only the credentials for the components you actually run are required:
#   - Web UI needs GP_AUTH_DATA
#   - Telegram bot needs GP_AUTH_DATA + TG_*

# ---- Google Photos auth ----
# Scraped from the Google Photos Android app — see README.
# Format: androidId=...&app=com.google.android.apps.photos&...&Token=aas_et/...
GP_AUTH_DATA=

# ---- Telegram bot (only if running `gpix -mode bot` or `gpix -mode all`) ----
# Token from @BotFather
TG_BOT_TOKEN=
# api_id + api_hash from https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=
# Your own Telegram user id (DM @userinfobot to find it).
# Only this user's commands are honored.
TG_OWNER_ID=

# ---- Optional ----
TG_SESSION_FILE=gpixbot.session
TG_TEMP_DIR=
TG_MAX_CONCURRENT=2
